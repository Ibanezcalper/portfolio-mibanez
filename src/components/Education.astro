---
const EDUCATION = [
  {
    institution: "Generation México / AWS re/Start",
    area: "Cloud Computing & Artificial Intelligence",
    degree: "Bootcamp",
    date: "Febrero 2026 - Junio 2026",
  },
  {
    institution: "Universidad Nacional Autónoma de México",
    area: "Administración de Organizaciones",
    degree: "Maestría (MS)",
    date: "2025 - 2026",
  },
  {
    institution: "Universidad Autónoma Chapingo",
    area: "Economía Agrícola",
    degree: "Ingeniería",
    date: "2018 - 2022",
  },
];
---

<div class="flex flex-col gap-y-10">
  {
    EDUCATION.map(({ institution, area, degree, date }) => (
      <div class="relative mx-12 pb-4 grid before:absolute before:left-[-35px] before:block before:h-full before:border-l-2 before:border-black/20 dark:before:border-white/15 before:content-['']">
        <div class="relative">
          <span class="text-yellow-400 -left-[42px] absolute rounded-full text-5xl">&bull;</span>
          <h3 class="text-xl font-bold text-yellow-400">{degree} en {area}</h3>
          <h4 class="font-semibold text-xl text-gray-600 dark:text-white">{institution}</h4>
          <time class="p-0 m-0 text-sm text-gray-600/80 dark:text-white/80">{date}</time>
        </div>
      </div>
    ))
  }
</div>
