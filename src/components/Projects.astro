---
import GitHub from "./icons/GitHub.astro";
import NextJS from "./icons/NextJS.astro";
import Tailwind from "./icons/Tailwind.astro";
import Link from "./icons/Link.astro";
import LinkButton from "./LinkButton.astro";
import Python from "./icons/Python.astro";

const TAGS = {
  NEXT: {
    name: "Next.js",
    class: "bg-black text-white",
    icon: NextJS,
  },
  TAILWIND: {
    name: "Tailwind CSS",
    class: "bg-[#003159] text-white",
    icon: Tailwind,
  },
  PYTHON: {
    name: "Python",
    class: "bg-[#3776AB] text-white",
    icon: Python,
  },
  AWS: {
    name: "AWS",
    class: "bg-[#232F3E] text-white",
    icon: GitHub, // Fallback to GitHub icon if AWS icon not available
  },
  ML: {
    name: "Machine Learning",
    class: "bg-[#FF9900] text-black",
    icon: GitHub, // Fallback to GitHub icon
  },
};
const PROJECTS = [
  {
    title: "SageMaker Churn Prediction",
    description:
      "Implementación de un pipeline de Machine Learning (MLOps) end-to-end en AWS SageMaker para la predicción de fuga de clientes utilizando XGBoost. Gestión de almacenamiento de datos y artefactos en AWS S3.",
    link: "https://github.com/ibanezcalper",
    github: "https://github.com/ibanezcalper",
    image: "/projects/sagemaker.webp",
    tags: [TAGS.AWS, TAGS.ML, TAGS.PYTHON],
  },
  {
    title: "Pronósticos PEA y Turismo",
    description:
      "Modelado predictivo de series de tiempo (SARIMA) para analizar la Población Económicamente Activa y tendencias turísticas en México. Generación de insights estratégicos para la toma de decisiones.",
    link: "https://github.com/ibanezcalper",
    github: "https://github.com/ibanezcalper",
    image: "/projects/turismo.webp",
    tags: [TAGS.PYTHON, TAGS.ML],
  },
  {
    title: "Webscrapping Tools",
    description:
      "Scrapers avanzados para plataformas dinámicas (JavaScript) como Lamudi y AirBNB. Automatización de recolección masiva y limpieza de información no estructurada.",
    github: "https://github.com/ibanezcalper",
    image: "/projects/scraping.webp",
    tags: [TAGS.PYTHON],
  },
  {
    title: "QGIS Python Scripts (PyQGIS)",
    description:
      "Automatización de análisis geoespacial masivo y reparación de geometrías. Integración de scripts personalizados para la modernización y actualización catastral municipal.",
    github: "https://github.com/ibanezcalper",
    image: "/projects/catastro.webp",
    tags: [TAGS.PYTHON],
  },
  {
    title: "Lab-AWS-Servicios-IA",
    description:
      "Desarrollo de soluciones de visión computacional y procesamiento de voz utilizando APIs de AWS (Rekognition, Transcribe, Polly) integradas mediante Boto3.",
    github: "https://github.com/ibanezcalper",
    image: "/projects/aws-lab.webp",
    tags: [TAGS.AWS, TAGS.PYTHON],
  },
  {
    title: "Utilidades de Productividad IA",
    description:
      "Scripts para automatización administrativa utilizando modelos de IA (OpenAI Whisper) para transcripción de audio y manipulación masiva de PDFs.",
    github: "https://github.com/ibanezcalper",
    image: "/projects/productivity.webp",
    tags: [TAGS.PYTHON, TAGS.ML],
  },
];
---

<div class="flex flex-col gap-y-16">
  {
    PROJECTS.map(
      ({ image, images, title, description, tags, link, github }) => (
        <article class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-8 md:space-y-0 md:items-center">
          <div class="w-full md:w-1/2">
            <div class="relative flex flex-col items-center col-span-6 row-span-5 gap-8 transition duration-500 ease-in-out transform shadow-xl overflow-clip rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-2xl lg:border lg:border-gray-800 lg:hover:border-gray-700 lg:hover:bg-gray-800/50">
              {images ? (
                <div class="relative w-full aspect-video transition duration-500 md:scale-110 md:group-hover:scale-105 overflow-hidden">
                  {images.map((img, index) => (
                    <img
                      alt={title}
                      class="absolute inset-0 object-cover object-center w-full h-full animate-carousel"
                      style={`animation-delay: ${index * 3}s;`}
                      loading="lazy"
                      src={img}
                    />
                  ))}
                </div>
              ) : (
                <img
                  alt={title}
                  class="object-cover object-center w-full aspect-video transition duration-500 sm:h-full md:scale-110 md:group-hover:scale-105"
                  loading="lazy"
                  src={image}
                />
              )}
            </div>
          </div>

          <div class="w-full md:w-1/2 md:max-w-lg">
            <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
              {title}
            </h3>
            <div class="flex flex-wrap mt-2">
              <ul class="flex flex-row mb-2 gap-x-2">
                {tags.map((tag) => (
                  <li>
                    <span
                      class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2 `}
                    >
                      <tag.icon class="size-4" />
                      {tag.name}
                    </span>
                  </li>
                ))}
              </ul>

              <div class="mt-2 text-gray-700 dark:text-gray-400">
                {description}
              </div>
              <footer class="flex items-end justify-start mt-4 gap-x-4">
                {github && (
                  <LinkButton href={github}>
                    <GitHub class="size-6" />
                    Code
                  </LinkButton>
                )}
                {link && (
                  <LinkButton href={link}>
                    <Link class="size-4" />
                    Preview
                  </LinkButton>
                )}
              </footer>
            </div>
          </div>
        </article>
      ),
    )
  }
</div>

<style>
  .animate-carousel {
    opacity: 0;
    animation: carousel-fade 9s infinite both;
  }

  @keyframes carousel-fade {
    0%,
    33.33% {
      opacity: 1;
      z-index: 10;
    }
    33.34%,
    100% {
      opacity: 0;
      z-index: 0;
    }
  }
</style>
